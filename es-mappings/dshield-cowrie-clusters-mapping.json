{
  "_comment": "Cluster centroid index. One doc per cluster per run, plus one run-summary doc per run. Parallel naming to dshield-cowrie-enrichment-mapping.json.",
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "refresh_interval": "30s"
  },
  "mappings": {
    "properties": {
      "@timestamp":    { "type": "date" },
      "run_id":        { "type": "keyword" },
      "doc_type":      { "type": "keyword" },

      "cluster_id":    { "type": "keyword" },
      "size":          { "type": "long" },
      "centroid": {
        "type": "dense_vector",
        "dims": 768,
        "index": false
      },
      "sample_commands": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 8192 } }
      },

      "total_docs":    { "type": "long" },
      "n_clusters":    { "type": "long" },
      "n_outliers":    { "type": "long" },
      "runtime_seconds": { "type": "float" }
    }
  }
}
