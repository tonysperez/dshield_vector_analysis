{
  "_comment": "External threat-intel for IP artifacts. One doc per IP, keyed by source.ip / artifact.value (same value). Written by `dshield_prism intel refresh`. Provider-specific raw responses live under providers.<name>.raw (disabled-index); structured fields under providers.<name>.structured. The derived block is recomputed every refresh and is what the rest of the pipeline reads.",
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "refresh_interval": "30s"
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "artifact": {
        "properties": {
          "kind":                    { "type": "keyword" },
          "value":                   { "type": "keyword" },
          "first_observed_locally":  { "type": "date" }
        }
      },

      "last_refreshed":              { "type": "date" },

      "providers": {
        "type": "object",
        "dynamic": true,
        "properties": {
          "tor": {
            "properties": {
              "fetched_at":          { "type": "date" },
              "ttl_expires_at":      { "type": "date" },
              "malicious":           { "type": "boolean" },
              "confidence":          { "type": "integer" },
              "label":               { "type": "keyword" },
              "tags":                { "type": "keyword" },
              "structured": {
                "properties": {
                  "is_exit":         { "type": "boolean" },
                  "list_size":       { "type": "long" }
                }
              },
              "raw": { "type": "object", "enabled": false }
            }
          },
          "feodotracker": {
            "properties": {
              "fetched_at":          { "type": "date" },
              "ttl_expires_at":      { "type": "date" },
              "malicious":           { "type": "boolean" },
              "confidence":          { "type": "integer" },
              "label":               { "type": "keyword" },
              "tags":                { "type": "keyword" },
              "structured": {
                "properties": {
                  "is_active_c2":    { "type": "boolean" },
                  "malware_family":  { "type": "keyword" },
                  "port":            { "type": "integer" },
                  "first_seen":      { "type": "keyword" },
                  "list_size":       { "type": "long" }
                }
              },
              "raw": { "type": "object", "enabled": false }
            }
          },
          "firehol": {
            "properties": {
              "fetched_at":          { "type": "date" },
              "ttl_expires_at":      { "type": "date" },
              "malicious":           { "type": "boolean" },
              "confidence":          { "type": "integer" },
              "label":               { "type": "keyword" },
              "tags":                { "type": "keyword" },
              "structured": {
                "properties": {
                  "matched":         { "type": "boolean" },
                  "matched_net":     { "type": "keyword" },
                  "list_size_ips":   { "type": "long" },
                  "list_size_nets":  { "type": "long" }
                }
              },
              "raw": { "type": "object", "enabled": false }
            }
          },
          "isc": {
            "properties": {
              "fetched_at":          { "type": "date" },
              "ttl_expires_at":      { "type": "date" },
              "malicious":           { "type": "boolean" },
              "confidence":          { "type": "integer" },
              "label":               { "type": "keyword" },
              "tags":                { "type": "keyword" },
              "structured": {
                "properties": {
                  "in_top":          { "type": "boolean" },
                  "reports":         { "type": "long" },
                  "targets":         { "type": "long" },
                  "list_size":       { "type": "long" }
                }
              },
              "raw": { "type": "object", "enabled": false }
            }
          }
        }
      },

      "derived": {
        "properties": {
          "consensus_malicious":     { "type": "boolean" },
          "consensus_label":         { "type": "keyword" },
          "tags":                    { "type": "keyword" },
          "providers_with_data":     { "type": "integer" },
          "providers_total":         { "type": "integer" },
          "external_rarity_score":   { "type": "float" }
        }
      }
    }
  }
}
