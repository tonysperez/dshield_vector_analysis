# Copy to .env and fill in. Loaded by config.py via pydantic-settings.

# Elasticsearch credentials (use a dedicated worker user, NOT SO admin)
ES_USERNAME=dshield_enrich
ES_PASSWORD=changeme
# Or use API key instead of user/pass:
# ES_API_KEY=base64string

# Cloud LLM escalation. Required when cloud.enabled=true in YAML.
# ANTHROPIC_API_KEY=sk-ant-...

# Override config paths if needed
# DSHIELD_ENRICH_CONFIG=/etc/dshield_enrich/config.yaml
# DSHIELD_ENRICH_LOCAL_CONFIG=/etc/dshield_enrich/local.yaml
# DSHIELD_ENRICH_ENV=/etc/dshield_enrich/.env
