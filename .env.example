# Copy to .env and fill in. Loaded by config.py via pydantic-settings.

# Elasticsearch credentials (use a dedicated worker user, NOT SO admin)
ES_USERNAME=dshield_prism
ES_PASSWORD=changeme
# Or use API key instead of user/pass:
# ES_API_KEY=base64string

# Cloud LLM escalation. Required when cloud.enabled=true in YAML.
# ANTHROPIC_API_KEY=sk-ant-...

# Intel subsystem provider keys (optional). When unset:
#   - GreyNoise / AbuseIPDB providers silently skip construction.
#   - abuse.ch providers (URLhaus / ThreatFox / FeodoTracker / future
#     MalwareBazaar) fall back to unauthenticated endpoints — works for
#     low volume but tighter rate limits + larger 429 risk.
#
#   GreyNoise Community  — https://www.greynoise.io/ (50 lookups/week free)
#   AbuseIPDB            — https://www.abuseipdb.com/ (1,000 checks/day free)
#   abuse.ch (shared)    — https://auth.abuse.ch/ — ONE key covers URLhaus,
#                          ThreatFox, FeodoTracker, MalwareBazaar
# GREYNOISE_API_KEY=...
# ABUSEIPDB_API_KEY=...
# ABUSE_CH_AUTH_KEY=...

# Override config paths if needed
# PRISM_CONFIG=/etc/dshield_prism/config.yaml
# PRISM_LOCAL_CONFIG=/etc/dshield_prism/local.yaml
# PRISM_ENV=/etc/dshield_prism/.env
